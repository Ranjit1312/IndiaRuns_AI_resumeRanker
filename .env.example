# Copy to .env for LOCAL runs. On the HF Space, users paste their key in the sidebar
# (session-only — never stored server-side or logged).
GOOGLE_API_KEY=your-google-ai-studio-key-here

# Optional defaults
HARNESS_MODEL=gemma-4-26b-a4b-it        # or gemma-4-31b-it, gemini-3-flash
HARNESS_MAX_REPAIRS=3
